<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- Welcome text for landlord -->
    <TextView
        android:id="@+id/landlordWelcome"
        android:text="Landlord Dashboard"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <!-- Example button for adding listings -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/addListingBtn"
        style="@style/Widget.BrokenHub.Button"
        android:text="Add New Listing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>




